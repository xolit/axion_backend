<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin Dashboard</title>
  <style>
    body { font-family: Arial, sans-serif; margin: 24px; }
    h1, h2 { margin-bottom: 8px; }
    form { margin-bottom: 20px; padding: 16px; border: 1px solid #ccc; border-radius: 8px; }
    label { display: block; margin: 8px 0 4px; }
    input[type="text"], textarea { width: 100%; padding: 8px; box-sizing: border-box; }
    textarea { min-height: 80px; }
    .message { padding: 10px; border-radius: 6px; margin-bottom: 16px; }
    .success { background: #e6ffec; border: 1px solid #72c577; color: #166b26; }
    .error { background: #ffe6e6; border: 1px solid #d15656; color: #7a1d1d; }
    .movie-item { margin-bottom: 24px; }
    .movie-item h3 { margin: 0 0 8px; }
    .movie-actions { display: flex; gap: 8px; margin-top: 8px; }
    button { padding: 8px 14px; cursor: pointer; }
    section { margin-bottom: 40px; }
    #notifMessage { margin-top: 10px; }
    #submit_btn_fornotif_add { margin-top: 10px; padding: 10px 20px; cursor: pointer; }
    .notifications-table-container { overflow-x: auto; }
    .notifications-table { width: 100%; border-collapse: collapse; margin-top: 10px; }
    .notifications-table thead tr { background-color: #f5f5f5; border-bottom: 2px solid #ddd; }
    .notifications-table th { padding: 10px; text-align: left; }
    .notifications-table td { padding: 10px; border-bottom: 1px solid #ddd; }
    .notifications-table .actions { text-align: center; }
    .delete-btn { background-color: #d15656; color: white; padding: 6px 12px; border: none; border-radius: 4px; cursor: pointer; }
    .delete-btn:hover { background-color: #c14444; }
    #deleteMessage { margin-top: 15px; }
  </style>
</head>
<body>
  <h1>Admin Dashboard</h1>
  <p>Use <strong>accessToken</strong> and <strong>adminPass</strong> in the query string to access this page.</p>

  <% if (success) { %>
    <div class="message success"><%= success %></div>
  <% } %>
  <% if (error) { %>
    <div class="message error"><%= error %></div>
  <% } %>

  <!-- Movies Management Section -->
  <h2>Movie Management</h2>
  <%- include('./admin/search-movie') %>
  <%- include('./admin/add-movie') %>
  <%- include('./admin/existing-movies') %>
  <%- include('./admin/movie-requests') %>

  <!-- Notifications Management Section -->
  <h2>Notification Management</h2>
  <%- include('./admin/add-notification') %>
  <%- include('./admin/existing-notifications') %>

  <script>
    // Handle notification form submission
    async function handleNotificationSubmit(event) {
      if (event) {
        event.preventDefault();
        event.stopPropagation();
      }
      
      const notifMessage = document.getElementById('notifMessage');
      const titleInput = document.getElementById('notifTitle');
      const descriptionInput = document.getElementById('notifDescription');
      const submitButton = document.getElementById('submit_btn_fornotif_add');
      
      if (!titleInput || !descriptionInput) {
        console.error('Form inputs not found');
        notifMessage.innerHTML = '<div class="message error">Form inputs not found</div>';
        return false;
      }
      
      const title = titleInput.value.trim();
      const description = descriptionInput.value.trim();

      if (!title) {
        notifMessage.innerHTML = '<div class="message error">Title is required.</div>';
        return false;
      }

      const accessToken = '<%= accessToken %>';
      const adminPass = '<%= adminPass %>';
      
      submitButton.disabled = true;
      
      try {
        const response = await fetch('/notifs/admin/add?accessToken=' + encodeURIComponent(accessToken) + '&adminPass=' + encodeURIComponent(adminPass), {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ title, description })
        });
        
        console.log('Response status:', response.status);
        
        const result = await response.json();
        console.log('Result:', result);
        
        if (response.ok && (result.ok || result.message)) {
          notifMessage.innerHTML = '<div class="message success">' + (result.message || 'Notification added successfully!') + '</div>';
          document.getElementById('notifTitle').value = '';
          document.getElementById('notifDescription').value = '';
          submitButton.disabled = false;
          setTimeout(() => { 
            notifMessage.innerHTML = ''; 
            location.reload();
          }, 1500);
        } else {
          notifMessage.innerHTML = '<div class="message error">' + (result.error || 'Failed to add notification') + '</div>';
          submitButton.disabled = false;
        }
      } catch (err) {
        console.error('Error:', err);
        notifMessage.innerHTML = '<div class="message error">Error: ' + err.message + '</div>';
        submitButton.disabled = false;
      }
      return false;
      return false;
    }
  </script>
</body>
</html>
