<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin Movie Management</title>
  <style>
    body { font-family: Arial, sans-serif; margin: 24px; }
    h1, h2 { margin-bottom: 8px; }
    form { margin-bottom: 20px; padding: 16px; border: 1px solid #ccc; border-radius: 8px; }
    label { display: block; margin: 8px 0 4px; }
    input[type="text"], textarea { width: 100%; padding: 8px; box-sizing: border-box; }
    textarea { min-height: 80px; }
    .message { padding: 10px; border-radius: 6px; margin-bottom: 16px; }
    .success { background: #e6ffec; border: 1px solid #72c577; color: #166b26; }
    .error { background: #ffe6e6; border: 1px solid #d15656; color: #7a1d1d; }
    .movie-item { margin-bottom: 24px; }
    .movie-item h3 { margin: 0 0 8px; }
    .movie-actions { display: flex; gap: 8px; margin-top: 8px; }
    button { padding: 8px 14px; cursor: pointer; }
  </style>
</head>
<body>
  <h1>Admin Movie Management</h1>
  <p>Use <strong>accessToken</strong> and <strong>adminPass</strong> in the query string to access this page.</p>

  <% if (success) { %>
    <div class="message success"><%= success %></div>
  <% } %>
  <% if (error) { %>
    <div class="message error"><%= error %></div>
  <% } %>

  <section>
    <h2>Search Existing Movie</h2>
    <form action="/admin" method="get">
      <input type="hidden" name="accessToken" value="<%= accessToken %>" />
      <input type="hidden" name="adminPass" value="<%= adminPass %>" />

      <label for="searchTitle">Title</label>
      <input id="searchTitle" name="searchTitle" type="text" value="<%= searchTitle || '' %>" placeholder="Search by title" />
      <button type="submit">Search</button>
      <% if (searchTitle) { %>
        <a href="/admin?accessToken=<%= encodeURIComponent(accessToken) %>&adminPass=<%= encodeURIComponent(adminPass) %>">Clear search</a>
      <% } %>
    </form>
  </section>

  <section>
    <h2>Add a New Movie</h2>
    <form action="/admin/movie/add?accessToken=<%= encodeURIComponent(accessToken) %>&adminPass=<%= encodeURIComponent(adminPass) %>" method="post">
      <input type="hidden" name="accessToken" value="<%= accessToken %>" />
      <input type="hidden" name="adminPass" value="<%= adminPass %>" />

      <label for="title">Title</label>
      <input id="title" name="title" type="text" required />

      <label for="release">Release</label>
      <input id="release" name="release" type="text" />

      <label for="Type">Genres / Type (comma separated)</label>
      <input id="Type" name="Type" type="text" placeholder="Action, Comedy, Drama" />

      <label for="Source">Sources (paste URLs or use key=value format)</label>
      <textarea id="Source" name="Source" placeholder="https://multimovies.com/movie/123&#10;https://onemovies.io/watch/456&#10;or&#10;Multimovies=https://multimovies.com/movie/123&#10;OneMovies=https://onemovies.io/watch/456"></textarea>

      <label for="bannerUrl">Banner URL</label>
      <input id="bannerUrl" name="bannerUrl" type="text" />

      <button type="submit">Add Movie</button>
    </form>
  </section>

  <section>
    <h2>Upcoming Movie Requests</h2>
    <% if (!upcomingRequests || upcomingRequests.length === 0) { %>
      <p>No pending requests found.</p>
    <% } else { %>
      <ul>
        <% upcomingRequests.forEach((request) => { %>
          <li>
            <strong><%= request.title %></strong>
            <span>(requested at <%= new Date(request.requestedAt).toLocaleString() %>)</span>
            <div>Status: <strong><%= request.status %></strong></div>
            <% if (request.message) { %>
              <div><em><%= request.message %></em></div>
            <% } %>
            <div class="request-actions">
              <% ['pending', 'approved', 'rejected'].forEach((status) => { %>
                <form action="/admin/request/status/<%= request._id %>?accessToken=<%= encodeURIComponent(accessToken) %>&adminPass=<%= encodeURIComponent(adminPass) %>" method="post" style="display:inline-block; margin-right:8px;">
                  <input type="hidden" name="status" value="<%= status %>" />
                  <input type="hidden" name="accessToken" value="<%= accessToken %>" />
                  <input type="hidden" name="adminPass" value="<%= adminPass %>" />
                  <button type="submit" <%= request.status === status ? 'disabled' : '' %>><%= status.charAt(0).toUpperCase() + status.slice(1) %></button>
                </form>
              <% }); %>
            </div>
          </li>
        <% }); %>
      </ul>
    <% } %>
  </section>

  <section>
    <h2>Existing Movies</h2>
    <% if (!searchTitle) { %>
      <p>Search for a title to see and manage matching movies.</p>
    <% } else if (!movies || movies.length === 0) { %>
      <p>No movies found for "<%= searchTitle %>".</p>
    <% } %>

    <% if (searchTitle && movies && movies.length > 0) { %>
      <% movies.forEach((movie) => { %>
      <div class="movie-item">
        <h3><%= movie.title %> (<%= movie.release || 'unknown' %>)</h3>
        <form action="/admin/movie/update/<%= movie._id %>?accessToken=<%= encodeURIComponent(accessToken) %>&adminPass=<%= encodeURIComponent(adminPass) %>" method="post">
          <input type="hidden" name="accessToken" value="<%= accessToken %>" />
          <input type="hidden" name="adminPass" value="<%= adminPass %>" />
          <% if (searchTitle) { %>
            <input type="hidden" name="searchTitle" value="<%= searchTitle %>" />
          <% } %>

          <label>Title</label>
          <input name="title" type="text" value="<%= movie.title %>" required />

          <label>Release</label>
          <input name="release" type="text" value="<%= movie.release || '' %>" />

          <label>Genres / Type</label>
          <input name="Type" type="text" value="<%= (movie.Type || []).join(', ') %>" />

          <label>Sources</label>
          <textarea name="Source"><%=
            (movie.Source && Object.entries(movie.Source).map(([key, value]) => `${key}=${value}`).join('\n')) || ''
          %></textarea>

          <label>Banner URL</label>
          <input name="bannerUrl" type="text" value="<%= movie.bannerUrl || '' %>" />

          <div class="movie-actions">
            <button type="submit">Update</button>
        </form>
        <form action="/admin/movie/delete/<%= movie._id %>?accessToken=<%= encodeURIComponent(accessToken) %>&adminPass=<%= encodeURIComponent(adminPass) %>" method="post" style="margin:0;">
          <input type="hidden" name="accessToken" value="<%= accessToken %>" />
          <input type="hidden" name="adminPass" value="<%= adminPass %>" />
          <% if (searchTitle) { %>
            <input type="hidden" name="searchTitle" value="<%= searchTitle %>" />
          <% } %>
          <button type="submit">Delete</button>
        </form>
          </div>
      </div>
    <% }); %>
    <% } %>
  </section>
</body>
</html>
