<section>
  <h2>All Notifications</h2>
  <% if (!notifications || notifications.length === 0) { %>
    <p>No notifications found.</p>
  <% } else { %>
    <div class="notifications-table-container">
      <table class="notifications-table">
        <thead>
          <tr>
            <th>Title</th>
            <th>Description</th>
            <th>Created</th>
            <th class="actions">Actions</th>
          </tr>
        </thead>
        <tbody id="notificationsTableBody">
          <% notifications.forEach((notif) => { %>
            <tr data-notif-id="<%= notif._id %>">
              <td><strong><%= notif.title %></strong></td>
              <td><%= notif.description || '-' %></td>
              <td><%= new Date(notif.createdAt).toLocaleString() %></td>
              <td class="actions">
                <button class="delete-btn delete-notification-btn" data-notif-id="<%= notif._id %>">Delete</button>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  <% } %>
  <div id="deleteMessage"></div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const deleteButtons = document.querySelectorAll('.delete-notification-btn');
    deleteButtons.forEach(btn => {
      btn.addEventListener('click', function(e) {
        const notifId = this.getAttribute('data-notif-id');
        deleteNotification(notifId);
      });
    });
  });

  function deleteNotification(notifId) {
    if (!confirm('Are you sure you want to delete this notification?')) {
      return;
    }

    const deleteMessage = document.getElementById('deleteMessage');
    const accessToken = '<%= accessToken %>';
    const adminPass = '<%= adminPass %>';

    fetch('/notifs/admin/delete/' + notifId + '?accessToken=' + encodeURIComponent(accessToken) + '&adminPass=' + encodeURIComponent(adminPass), {
      method: 'DELETE',
      headers: { 'Content-Type': 'application/json' }
    })
    .then(response => response.json())
    .then(result => {
      if (result.ok || result.message) {
        deleteMessage.innerHTML = '<div class="message success">' + (result.message || 'Notification deleted successfully!') + '</div>';
        setTimeout(() => {
          location.reload();
        }, 1500);
      } else {
        deleteMessage.innerHTML = '<div class="message error">' + (result.error || 'Failed to delete notification') + '</div>';
      }
    })
    .catch(err => {
      deleteMessage.innerHTML = '<div class="message error">Error: ' + err.message + '</div>';
      console.error('Error:', err);
    });
  }
</script>
