<section>
  <h2>Add a New Movie</h2>
  <form
    action="/admin/movie/add?accessToken=<%= encodeURIComponent(accessToken) %>&adminPass=<%= encodeURIComponent(adminPass) %>"
    method="post"
    id="addMovieForm"
  >
    <input type="hidden" name="accessToken" value="<%= accessToken %>" />
    <input type="hidden" name="adminPass" value="<%= adminPass %>" />

    <label for="title">Title</label>
    <input
      id="title"
      name="title"
      type="text"
      placeholder="Enter movie title ex- Avengers"
      required
    />

    <label for="release">Release</label>
    <input
      id="release"
      name="release"
      type="text"
      placeholder="Enter release date ex- 2026"
    />

    <label for="SubGenere">SubGenre</label>
    <input
      id="SubGenere"
      name="SubGenere"
      type="text"
      placeholder="Movie, TvShow"
    />

    <label for="Wood">Wood</label>
    <input
      id="Wood"
      name="Wood"
      type="text"
      placeholder="Bollywood, Hollywood"
    />

    <label for="MultimoviesDomain">Multimovies domain? ex- .homes</label>
    <input type="text" id="MultimoviesDomain" name="MultimoviesDomain" />

    <label for="CineHDDomain">CineHD domain? ex- .homes</label>
    <input type="text" id="CineHDDomain" name="CineHDDomain" />

    <label for="Source">Sources (paste URLs or use key=value format)</label>
    <textarea
      id="Source"
      name="Source"
      placeholder="https://multimovies.com/movie/123&#10;https://onemovies.io/watch/456&#10;or&#10;Multimovies=https://multimovies.com/movie/123&#10;OneMovies=https://onemovies.io/watch/456"
    ></textarea>

    <button type="submit">Add Movie</button>
  </form>
</section>

<script>
  const savedDomainForMultiMovies = localStorage.getItem(
    "MultimoviesDomainInput",
  );
  const savedDomainForCineHD = localStorage.getItem("CineHDDomainInput");
  if (savedDomainForMultiMovies) {
    document.getElementById("MultimoviesDomain").value =
      savedDomainForMultiMovies;
  }
  if (savedDomainForCineHD) {
    document.getElementById("CineHDDomain").value = savedDomainForCineHD;
  }

  const addMovieForm = document.getElementById("addMovieForm");
  const MultimoviesDomainInput = document.getElementById("MultimoviesDomain");
  addMovieForm.addEventListener("onsubmit", (e) => {
    e.preventDefault();

    if (!localStorage.getItem("MultimoviesDomainInput")) {
      localStorage.setItem(
        "MultimoviesDomainInput",
        MultimoviesDomainInput.value,
      );
    } else if (!localStorage.getItem("CineHDDomainInput")) {
      localStorage.setItem(
        "CineHDDomainInput",
        document.getElementById("CineHDDomain").value,
      );
    }
  });
</script>
